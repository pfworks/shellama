{
  "api_keys": {
    "sk-admin-change-me": {
      "name": "admin",
      "role": "admin",
      "models": ["all"]
    },
    "sk-user-change-me": {
      "name": "user",
      "role": "user",
      "models": ["llama3.2:1b", "llama3.2:3b", "qwen2.5-coder:7b"],
      "cloud_fallback": true
    },
    "sk-viewer-change-me": {
      "name": "viewer",
      "role": "viewer",
      "models": []
    }
  },

  "_comment_sso": "Uncomment ONE of the sso blocks below",

  "_sso_keycloak_example": {
    "provider": "keycloak",
    "issuer": "https://keycloak.example.com/realms/shellama",
    "client_id": "shellama",
    "client_secret": "your-client-secret",
    "secret_key": "random-flask-session-secret",
    "default_role": "viewer",
    "role_mapping": {
      "admin": ["shellama-admin"],
      "user": ["shellama-user"],
      "viewer": ["shellama-viewer"]
    }
  },

  "_sso_azure_ad_example": {
    "provider": "azure",
    "issuer": "https://login.microsoftonline.com/YOUR-TENANT-ID/v2.0",
    "client_id": "your-app-client-id",
    "client_secret": "your-client-secret",
    "secret_key": "random-flask-session-secret",
    "default_role": "viewer",
    "role_mapping": {
      "admin": ["SheLLaMa-Admin"],
      "user": ["SheLLaMa-User"],
      "viewer": ["SheLLaMa-Viewer"]
    }
  }
}
