def extract_bash_blocks(text):
    """Extract bash code blocks from AI response."""
    blocks = re.findall(r'```bash\n(.*?)```', text, re.DOTALL)
    return [b.strip() for b in blocks if b.strip()]


def run_command(cmd):
    """Run a bash command with user's env (aliases/functions) and return stdout+stderr."""
    try:
        result = subprocess.run(
            ['bash', '-c', f'source {BASH_ENV} 2>/dev/null; {cmd}'],
            capture_output=True, text=True, timeout=30,
            cwd=os.getcwd()
        )
        output = result.stdout
        if result.stderr:
            output += result.stderr
        # Truncate long output
        lines = output.split('\n')
        if len(lines) > 100:
            output = '\n'.join(lines[:50] + [f'\n... ({len(lines) - 100} lines truncated) ...\n'] + lines[-50:])
        return output.strip()
    except subprocess.TimeoutExpired:
        return "(command timed out after 30s)"
    except Exception as e:
        return f"(error: {e})"


