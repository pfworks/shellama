def ai_test(args=None):
    """Benchmark: call /test on the API and display results."""
    global session_tokens, session_requests, session_elapsed

    # Parse args: ,test [model] [--prompt "..."]
    model_arg = None
    prompt = None
    if args:
        if '--prompt ' in args:
            parts = args.split('--prompt ', 1)
            model_arg = parts[0].strip() or None
            prompt = parts[1].strip().strip('"').strip("'")
        else:
            model_arg = args

    # If no model specified, show interactive picker
    if not model_arg:
        try:
            resp = _session.get(f"{API_URL}/models", timeout=10)
            models = [m['name'] for m in resp.json().get('models', [])]
        except Exception as e:
            print(f"shellama: {e}", file=sys.stderr)
            return
        if not models:
            print("shellama: no models available", file=sys.stderr)
            return
        # Get runnable info from queue-status
        runnable = set(models)
        try:
            qs = _session.get(f"{API_URL}/queue-status", timeout=10).json()
            backends = qs.get('backends', [])
            max_sizes = [b.get('max_model', '') for b in backends if b.get('status') == 'online']
            if max_sizes:
                import re
                def _ms(name):
                    m = re.search(r':(\d+\.?\d*)b', name)
                    return float(m.group(1)) if m else 0
                mx = max(_ms(m) for m in max_sizes)
                runnable = {m for m in models if _ms(m) <= mx}
        except Exception:
            pass
        print(f"{CYAN}Available models:{RESET}")
        for i, m in enumerate(models):
            current = " ← current" if m == MODEL else ""
            flag = f" {GRAY}(too large){RESET}" if m not in runnable else ""
            print(f"  {YELLOW}{i+1}{RESET}) {m}{current}{flag}")
        print(f"  {YELLOW}a{RESET}) all runnable models")
        try:
            choice = input(f"{GRAY}Select [1-{len(models)}/a]: {RESET}").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if choice == 'a':
            model_arg = 'all'
        elif choice.isdigit() and 1 <= int(choice) <= len(models):
            model_arg = models[int(choice)-1]
        else:
            print("cancelled")
            return

    # Build API request
    payload = {'model': model_arg}
    if prompt:
        payload['prompt'] = prompt

    display = (prompt or 'default test prompt')[:70]
    print(f"\n{CYAN}Benchmark: \"{display}\"{RESET}")
    print(f"{GRAY}Running via /test API...{RESET}\n")

    try:
        spinner.start()
        resp = _session.post(f"{API_URL}/test", json=payload, timeout=3600)
        spinner.stop()
        data = resp.json()
    except KeyboardInterrupt:
        spinner.stop()
        print(f"\n{GRAY}cancelled — stopping backend...{RESET}", file=sys.stderr)
        try:
            _session.post(f"{API_URL}/stop-all", timeout=5)
        except Exception:
            pass
        return
    except Exception as e:
        spinner.stop()
        print(f"shellama: {e}", file=sys.stderr)
        return

    if data.get('error'):
        print(f"shellama: {data['error']}", file=sys.stderr)
        return

    results = [r for r in data.get('results', []) if 'error' not in r]
    skipped = data.get('skipped', [])
    cloud_costs = data.get('cloud_costs', [])

    if skipped:
        print(f"{GRAY}Skipped (too large): {', '.join(skipped)}{RESET}")

    for r in data.get('results', []):
        if r.get('error'):
            print(f"{GRAY}{r['model']}: {r['error']}{RESET}")

    if not results:
        print("no results")
        return

    # Track session stats
    for r in results:
        session_tokens += r.get('total_tokens', 0)
        session_elapsed += r.get('elapsed', 0)
    session_requests += len(results)

    # Print comparison table
    print(f"\n{CYAN}{'Model':<30} {'Time':>7} {'Prompt':>7} {'Reply':>7} {'Total':>7} {'tok/s':>7}{RESET}")
    print(f"{GRAY}{'─'*30} {'─'*7} {'─'*7} {'─'*7} {'─'*7} {'─'*7}{RESET}")
    for r in sorted(results, key=lambda x: x['elapsed']):
        print(f"{r['model']:<30} {r['elapsed']:>6.1f}s {r['prompt_tokens']:>7} {r['response_tokens']:>7} {r['total_tokens']:>7} {r.get('tok_per_sec', 0):>6.1f}")

    # Cloud cost estimates from API
    if cloud_costs:
        print(f"\n{CYAN}Cloud cost estimate for this request:{RESET}")
        print(f"{GRAY}{'Provider':<25} {'Input':>10} {'Output':>10} {'Total':>10}{RESET}")
        print(f"{GRAY}{'─'*25} {'─'*10} {'─'*10} {'─'*10}{RESET}")
        for c in cloud_costs:
            print(f"{c['provider']:<25} ${c['input_cost']:>8.6f} ${c['output_cost']:>8.6f} ${c['total_cost']:>8.6f}")
        print(f"\n{GRAY}Local models: $0.00 (your electricity only){RESET}")


