def complete(text, state):
    """Tab completion: files/dirs + executables in PATH."""
    # Expand ~ 
    if text.startswith('~'):
        expanded = os.path.expanduser(text)
        matches = glob.glob(expanded + '*')
        matches = ['~' + m[len(os.path.expanduser('~')):] for m in matches]
    else:
        matches = glob.glob(text + '*')

    # Add trailing / for directories
    matches = [m + '/' if os.path.isdir(m) else m for m in matches]

    # If at start of line (no spaces before cursor), also complete commands from PATH
    line = readline.get_line_buffer()
    word_start = line[:readline.get_begidx()]
    if not word_start.strip():
        path_dirs = os.environ.get('PATH', '').split(':')
        for d in path_dirs:
            try:
                for f in os.listdir(d):
                    if f.startswith(text) and os.access(os.path.join(d, f), os.X_OK):
                        matches.append(f)
            except OSError:
                pass

    matches = sorted(set(matches))
    if state < len(matches):
        return matches[state]
    return None


readline.set_completer(complete)
