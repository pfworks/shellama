class LlamaSpinner:
    """Animated llama spinner for backend requests."""
    def __init__(self):
        self._thread = None
        self._stop = False

    def start(self):
        self._stop = False
        self._thread = __import__('threading').Thread(target=self._spin, daemon=True)
        self._thread.start()

    def _spin(self):
        import time
        i = 0
        while not self._stop:
            frame = LLAMA_FRAMES[i % len(LLAMA_FRAMES)]
            sys.stderr.write(f"\r{YELLOW}{frame}{RESET}")
            sys.stderr.flush()
            i += 1
            time.sleep(0.3)
        sys.stderr.write("\r" + " " * 20 + "\r")
        sys.stderr.flush()
        sys.stdout.flush()

    def stop(self):
        self._stop = True
        if self._thread:
            self._thread.join()


spinner = LlamaSpinner()


def ai_chat(message, model):
    """Single chat round with the backend. Returns (response, tokens, elapsed, error)."""
    global session_tokens, session_requests, session_elapsed
    try:
        payload = {'message': message, 'model': model, 'conversation_id': SESSION_CONV_ID}
        resp = _session.post(
            f"{API_URL}/chat",
            json=payload,
            timeout=3600
        )
        data = resp.json()
        if data.get('error'):
            return None, 0, 0, data['error']
        data = _handle_fallback(data, '/chat', payload)
        tokens = data.get('total_tokens', 0)
        elapsed = data.get('elapsed', 0)
        session_tokens += tokens
        session_requests += 1
        session_elapsed += elapsed
        response_text = data.get('response', '')
        if data.get('cloud_fallback'):
            response_text += f"\n{GRAY}[cloud fallback: {data.get('cloud_model', 'cloud')}]{RESET}"
        elif data.get('cached'):
            response_text += f"\n{GRAY}[cached]{RESET}"
        return response_text, tokens, elapsed, None
    except KeyboardInterrupt:
        # User hit Ctrl+C — tell backend to stop
        try:
            _session.post(f"{API_URL}/stop-all", timeout=5)
        except Exception:
            pass
        return None, 0, 0, 'cancelled'
    except requests.exceptions.ConnectionError:
        return None, 0, 0, f"cannot reach {API_URL}"
    except Exception as e:
        return None, 0, 0, str(e)


def ai_agent(query, quiet=False):
    """Agentic loop: AI can run commands and iterate."""
    global last_output
    os_info = subprocess.run(['uname', '-sr'], capture_output=True, text=True).stdout.strip()
    system = SYSTEM_PROMPT.format(os_info=os_info, cwd=os.getcwd())
    conversation = f"{system}\n\nUser: {query}"

    total_tokens = 0
    total_elapsed = 0

    for round_num in range(MAX_ROUNDS):
        if not quiet:
            spinner.start()
        response, tokens, elapsed, err = ai_chat(conversation, MODEL)
        if not quiet:
            spinner.stop()
        if err:
            print(f"shellama: {err}", file=sys.stderr)
            return

        total_tokens += tokens
        total_elapsed += elapsed

        commands = extract_bash_blocks(response)

        if not commands:
            # Final answer — always show, even in quiet mode
            last_output = response
            if quiet:
                print(response)
            else:
                print(f"{CYAN}{response}{RESET}")
                print(f"{GRAY}[{round_num + 1} round{'s' if round_num else ''} | {total_elapsed:.1f}s | {total_tokens} tokens | {MODEL}]{RESET}", file=sys.stderr)
            return

        if not quiet:
            # Show reasoning text between commands
            text_parts = re.split(r'```bash\n.*?```', response, flags=re.DOTALL)
            for part in text_parts:
                part = part.strip()
                if part:
                    print(f"{CYAN}{part}{RESET}")
            print(f"{GRAY}[round {round_num + 1} | {elapsed:.1f}s | {tokens} tokens]{RESET}", file=sys.stderr)

        # Execute each command and collect output
        cmd_outputs = []
        for cmd in commands:
            sys.stderr.write("\n")
            print(f"{YELLOW}┌─ $ {cmd}{RESET}")
            if not quiet:
                try:
                    import termios
                    termios.tcflush(sys.stdin, termios.TCIFLUSH)
                except Exception:
                    pass
                try:
                    answer = input(f"{YELLOW}└─ Run? [y/N/q] {RESET}").strip().lower()
                except (EOFError, KeyboardInterrupt):
                    print()
                    return
                if answer == 'q':
                    return
                if answer != 'y':
                    cmd_outputs.append(f"$ {cmd}\n(skipped by user)")
                    print(f"{GRAY}   (skipped){RESET}")
                    continue
            output = run_command(cmd)
            if output:
                if quiet:
                    print(output)
                else:
                    print(f"{DIM}{output}{RESET}")
            cmd_outputs.append(f"$ {cmd}\n{output}")

        # Feed results back
        results = '\n\n'.join(cmd_outputs)
        conversation += f"\n\nAssistant: {response}\n\nCommand output:\n{results}\n\nContinue. If you have enough information, give your final answer without any ```bash blocks."

    print(f"{GRAY}[max rounds reached | {total_elapsed:.1f}s | {total_tokens} tokens]{RESET}", file=sys.stderr)


def _handle_fallback(data, endpoint, payload):
    """Check if backend suggests cloud fallback, prompt user, retry if approved."""
    if not data.get('fallback_available'):
        return data
    reason = data.get('fallback_reason', 'low quality')
    model = data.get('fallback_model', 'cloud')
    print(f"\n{YELLOW}⚠ Local model produced poor output: {reason}{RESET}", file=sys.stderr)
    print(f"{YELLOW}  Recommended fallback: {model}{RESET}", file=sys.stderr)
    try:
        answer = input(f"{GRAY}Use cloud fallback? [y/N] {RESET}").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return data
    if answer != 'y':
        return data
    # Retry with force_cloud
    payload['force_cloud'] = True
    try:
        spinner.start()
        resp = _session.post(f"{API_URL}{endpoint}", json=payload, timeout=3600)
        spinner.stop()
        return resp.json()
    except Exception as e:
        spinner.stop()
        print(f"shellama: fallback failed: {e}", file=sys.stderr)
        return data


def ai_simple(endpoint, payload, result_key):
    """Simple one-shot API call to a backend endpoint."""
    global session_tokens, session_requests, session_elapsed, last_output
    try:
        spinner.start()
        resp = _session.post(f"{API_URL}{endpoint}", json=payload, timeout=3600)
        spinner.stop()
        data = resp.json()
        if data.get('error'):
            print(f"shellama: {data['error']}", file=sys.stderr)
            return
        data = _handle_fallback(data, endpoint, payload)
        session_tokens += data.get('total_tokens', 0)
        session_requests += 1
        session_elapsed += data.get('elapsed', 0)
        result = data.get(result_key, '')
        last_output = result
        if data.get('cloud_fallback'):
            print(f"{CYAN}{result}{RESET}")
            print(f"{GRAY}[{data.get('elapsed', 0):.1f}s | {data.get('total_tokens', 0)} tokens | {data.get('cloud_model', 'cloud')} (fallback)]{RESET}", file=sys.stderr)
        else:
            print(f"{CYAN}{result}{RESET}")
            tag = ' (cached)' if data.get('cached') else ''
            print(f"{GRAY}[{data.get('elapsed', 0):.1f}s | {data.get('total_tokens', 0)} tokens | {MODEL}{tag}]{RESET}", file=sys.stderr)
    except KeyboardInterrupt:
        spinner.stop()
        print(f"\n{GRAY}cancelled — stopping backend...{RESET}", file=sys.stderr)
        try:
            _session.post(f"{API_URL}/stop-all", timeout=5)
        except Exception:
            pass
    except requests.exceptions.ConnectionError:
        spinner.stop()
        print(f"shellama: cannot reach {API_URL}", file=sys.stderr)
    except Exception as e:
        spinner.stop()
        print(f"shellama: {e}", file=sys.stderr)


def ai_image(prompt):
    """Generate an image from a text prompt."""
    global session_requests, session_elapsed
    import base64
    image_model = os.environ.get('AI_IMAGE_MODEL', 'sdxl-turbo')
    steps = 4 if 'turbo' in image_model else 20
    try:
        spinner.start()
        resp = _session.post(
            f"{API_URL}/generate-image",
            json={'prompt': prompt, 'image_model': image_model, 'steps': steps, 'width': 512, 'height': 512},
            timeout=3600
        )
        spinner.stop()
        data = resp.json()
        if data.get('error'):
            print(f"shellama: {data['error']}", file=sys.stderr)
            return
        session_requests += 1
        session_elapsed += data.get('elapsed', 0)
        img_data = base64.b64decode(data['image'])
        default_name = f"generated_{int(__import__('time').time())}.png"
        if DOWNLOAD_DIR:
            os.makedirs(DOWNLOAD_DIR, exist_ok=True)
            default_path = os.path.join(DOWNLOAD_DIR, default_name)
        else:
            default_path = default_name
        try:
            custom = input(f"{GRAY}Save as [{default_path}]: {RESET}").strip()
        except (EOFError, KeyboardInterrupt):
            custom = ''
        outfile = custom if custom else default_path
        outdir = os.path.dirname(outfile)
        if outdir:
            os.makedirs(outdir, exist_ok=True)
        with open(outfile, 'wb') as f:
            f.write(img_data)
        print(f"{CYAN}{os.path.abspath(outfile)}{RESET}")
        print(f"{GRAY}[{data.get('elapsed', 0):.1f}s | {data.get('model', image_model)} | {data.get('steps', steps)} steps]{RESET}", file=sys.stderr)
    except KeyboardInterrupt:
        spinner.stop()
        print(f"\n{GRAY}cancelled — stopping backend...{RESET}", file=sys.stderr)
        try:
            _session.post(f"{API_URL}/stop-all", timeout=5)
        except Exception:
            pass
    except requests.exceptions.ConnectionError:
        spinner.stop()
        print(f"shellama: cannot reach {API_URL}", file=sys.stderr)
    except Exception as e:
        spinner.stop()
        print(f"shellama: {e}", file=sys.stderr)


def ai_analyze(paths):
    """Analyze files/directories via the /analyze endpoint."""
    files_data = []
    for p in paths:
        p = os.path.expanduser(p)
        if os.path.isdir(p):
            for root, dirs, files in os.walk(p):
                for f in files:
                    fp = os.path.join(root, f)
                    try:
                        with open(fp, 'r') as fh:
                            files_data.append({'path': fp, 'content': fh.read()})
                    except Exception:
                        pass
        elif os.path.isfile(p):
            try:
                with open(p, 'r') as fh:
                    files_data.append({'path': p, 'content': fh.read()})
            except Exception:
                pass
        else:
            print(f"shellama: {p}: not found", file=sys.stderr)
    if not files_data:
        print("shellama: no readable files found", file=sys.stderr)
        return
    print(f"{GRAY}Analyzing {len(files_data)} file{'s' if len(files_data) != 1 else ''}...{RESET}", file=sys.stderr)
    ai_simple('/analyze', {'files': files_data, 'model': MODEL}, 'analysis')


def read_file_arg(arg):
    """Read content from a file path argument."""
    path = os.path.expanduser(arg)
    try:
        with open(path, 'r') as f:
            return f.read()
    except Exception as e:
        print(f"shellama: {path}: {e}", file=sys.stderr)
        return None


def ai_save(filename):
    """Save last AI output to a file. Strips markdown code fences if the entire output is a single fenced block."""
    if not last_output:
        print("shellama: nothing to save (no AI output yet)", file=sys.stderr)
        return
    # Strip markdown code fences if output is a single fenced block
    content = last_output.strip()
    m = re.match(r'^```\w*\n(.*?)```$', content, re.DOTALL)
    if m:
        content = m.group(1)
    path = os.path.expanduser(filename)
    outdir = os.path.dirname(path)
    if outdir:
        os.makedirs(outdir, exist_ok=True)
    with open(path, 'w') as f:
        f.write(content)
    print(f"{CYAN}saved: {os.path.abspath(path)}{RESET}")


