def select_model():
    """List available models from backend and let user pick one."""
    global MODEL
    try:
        resp = _session.get(f"{API_URL}/models", timeout=10)
        models = resp.json().get('models', [])
    except Exception as e:
        print(f"shellama: {e}", file=sys.stderr)
        return
    if not models:
        print("shellama: no models available", file=sys.stderr)
        return
    print(f"{CYAN}Available models:{RESET}")
    print(f"  {YELLOW}0{RESET}) auto (smart routing){' ← current' if MODEL == 'auto' else ''}")
    for i, m in enumerate(models):
        size_gb = round(m.get('size', 0) / (1024**3), 1)
        current = " ← current" if m['name'] == MODEL else ""
        print(f"  {YELLOW}{i+1}{RESET}) {m['name']} ({size_gb}GB){current}")
    try:
        choice = input(f"{GRAY}Select [0-{len(models)}]: {RESET}").strip()
        if choice == '0':
            MODEL = 'auto'
            print(f"model: auto")
        elif choice.isdigit() and 1 <= int(choice) <= len(models):
            MODEL = models[int(choice)-1]['name']
            print(f"model: {MODEL}")
        else:
            print("cancelled")
    except (EOFError, KeyboardInterrupt):
        print()


def get_prompt():
    """Get shell prompt: AI_PS1 env var > bash PS1 > fallback."""
    ps1_source = os.environ.get('AI_PS1')
    try:
        if ps1_source:
            # Single-quote the value so bash sees literal \u, \h, etc.
            safe = ps1_source.replace("'", "'\\''")
            cmd = f"PS1='{safe}'; echo -n \"${{PS1@P}}\""
        else:
            cmd = 'echo -n "${PS1@P}"'
        result = subprocess.run(
            ['bash', '-ic', cmd],
            capture_output=True, text=True, timeout=2,
            cwd=os.getcwd()
        )
        if result.stdout:
            return result.stdout
    except Exception:
        pass
    cwd = os.getcwd().replace(os.path.expanduser('~'), '~')
    return f"{cwd} $ "


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    signal.signal(signal.SIGTSTP, signal.SIG_IGN)
    quiet = os.environ.get('AI_QUIET', '').lower() in ('1', 'true', 'yes')

    try:
        readline.read_history_file(HISTFILE)
    except FileNotFoundError:
        pass
    readline.set_history_length(10000)

    print(f"{CYAN}shellama{RESET} - bash + AI agent")
    print(f"{GRAY}backend: {API_URL} | model: {MODEL}{RESET}")
    print()
    print(f"  {YELLOW},{RESET}  <prompt>       agentic chat        {YELLOW},,{RESET} <prompt>       quiet chat")
    print(f"  {YELLOW},explain{RESET}  <file>  explain any file     {YELLOW},generate{RESET} <desc>  generate code")
    print(f"  {YELLOW},analyze{RESET}  <path>  analyze files/dirs   {YELLOW},img{RESET} <prompt>     generate image")
    print(f"  {YELLOW},save{RESET}  <filename>  save last output     {YELLOW},test{RESET}             benchmark models")
    print(f"  {YELLOW},models{RESET}           select model         {YELLOW},list{RESET}             all services")
    print(f"  {YELLOW},quiet{RESET}            toggle quiet")
    print()

    while True:
        try:
            line = input(HAL + get_prompt())
        except EOFError:
            print()
            break
        except KeyboardInterrupt:
            print()
            continue

        line = line.strip()
        if not line:
            continue

        if line in ('exit', 'quit', 'logout'):
            break
        if line == 'cd' or line.startswith('cd '):
            path = os.path.expanduser(line[3:].strip() or '~')
            try:
                os.chdir(path)
            except Exception as e:
                print(f"cd: {e}", file=sys.stderr)
            continue
        if line.startswith('export '):
            parts = line[7:].split('=', 1)
            if len(parts) == 2:
                os.environ[parts[0].strip()] = parts[1].strip()
            continue

        if line.startswith(TRIGGER + TRIGGER):
            # ,, prefix = one-shot quiet
            query = line[2:].strip()
            if query:
                ai_agent(query, quiet=True)
        elif line.startswith(TRIGGER):
            query = line[len(TRIGGER):].strip()
            if not query:
                continue
            if query == 'list' or query == 'help':
                show_services()
            elif query == 'models':
                select_model()
            elif query == 'quiet':
                quiet = not quiet
                print(f"quiet mode: {'on' if quiet else 'off'}")
            elif query == 'tokens':
                print(f"{CYAN}Session usage: {session_requests} requests | {session_tokens} tokens | {session_elapsed:.1f}s{RESET}")
            elif query.startswith('save '):
                ai_save(query[5:].strip())
            elif query == 'test' or query.startswith('test '):
                ai_test(query[5:].strip() or None)
            elif query.startswith('img '):
                ai_image(query[4:].strip())
            elif query.startswith('analyze '):
                ai_analyze(query[8:].strip().split())
            elif query.startswith('explain '):
                content = read_file_arg(query[8:].strip())
                if content:
                    # Auto-detect: try ansible explain first, fall back to code explain
                    ext = query[8:].strip().rsplit('.', 1)[-1].lower()
                    if ext in ('yml', 'yaml'):
                        ai_simple('/explain', {'playbook': content, 'model': MODEL}, 'explanation')
                    else:
                        ai_simple('/explain-code', {'code': content, 'model': MODEL}, 'explanation')
            elif query.startswith('generate '):
                desc = query[9:].strip()
                # Auto-detect: if it mentions ansible/playbook, use /generate
                if any(kw in desc.lower() for kw in ('ansible', 'playbook', 'shell command')):
                    ai_simple('/generate', {'commands': desc, 'model': MODEL}, 'playbook')
                else:
                    ai_simple('/generate-code', {'description': desc, 'model': MODEL}, 'code')
            else:
                ai_agent(query, quiet=quiet)
        else:
            subprocess.run(['bash', '-c', f'source {BASH_ENV} 2>/dev/null; {line}'])

    try:
        readline.write_history_file(HISTFILE)
    except Exception:
        pass
    try:
        os.unlink(BASH_ENV)
    except Exception:
        pass


if __name__ == '__main__':
    import sys as _sys
    if len(_sys.argv) > 1:
        # Non-interactive mode: shellama <command> [args...]
        cmd = _sys.argv[1]
        args = ' '.join(_sys.argv[2:]) if len(_sys.argv) > 2 else ''
        quiet = os.environ.get('AI_QUIET', '').lower() in ('1', 'true', 'yes')
        if cmd == 'agent':
            ai_agent(args, quiet=quiet)
        elif cmd == 'quiet':
            ai_simple('/chat', {'message': args, 'model': MODEL, 'conversation_id': SESSION_CONV_ID}, 'response')
        elif cmd == 'explain':
            content = read_file_arg(args)
            if content:
                ext = args.rsplit('.', 1)[-1].lower()
                if ext in ('yml', 'yaml'):
                    ai_simple('/explain', {'playbook': content, 'model': MODEL}, 'explanation')
                else:
                    ai_simple('/explain-code', {'code': content, 'model': MODEL}, 'explanation')
        elif cmd == 'generate':
            if any(kw in args.lower() for kw in ('ansible', 'playbook', 'shell command')):
                ai_simple('/generate', {'commands': args, 'model': MODEL}, 'playbook')
            else:
                ai_simple('/generate-code', {'description': args, 'model': MODEL}, 'code')
        elif cmd == 'analyze':
            ai_analyze(args.split())
        elif cmd == 'img':
            ai_image(args)
        elif cmd == 'test':
            ai_test(args or None)
        elif cmd == 'models':
            select_model()
        elif cmd == 'save':
            ai_save(args)
        elif cmd == 'tokens':
            try:
                since = os.environ.get('SHELLAMA_SESSION_START', '0')
                r = _session.get(f"{API_URL}/cost-history?since={since}", timeout=5).json()
                total = r.get('total_tokens', 0)
                prompt = r.get('prompt_tokens', 0)
                resp = r.get('response_tokens', 0)
                reqs = r.get('requests', 0)
                cached = r.get('cached', {}).get('requests', 0)
                print(f"{CYAN}Session: {reqs} requests | {total:,} tokens ({prompt:,} in + {resp:,} out) | {cached} cached{RESET}")
            except:
                print(f"{CYAN}Session usage: {session_requests} requests | {session_tokens} tokens | {session_elapsed:.1f}s{RESET}")
        elif cmd in ('list', 'help'):
            show_services()
        else:
            # Default: treat entire argv as agentic chat
            ai_agent(' '.join(_sys.argv[1:]), quiet=quiet)
    else:
        main()
